# Server-side DeepSeek key for api/deepseek.ts
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Optional client override for local proxy/dev routing.
# Defaults to http://localhost:3000/api/deepseek in dev and /api/deepseek in production.
VITE_DEEPSEEK_API_URL=

# Optional Twikoo overrides
VITE_TWIKOO_JS=
VITE_TWIKOO_ENV_ID=
VITE_TWIKOO_LANG=zh-CN
VITE_TWIKOO_REGION=
