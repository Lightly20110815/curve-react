{
  "name": "curve-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A React + Vite reimagining of the curve blog theme",
  "scripts": {
    "content": "tsx scripts/build-content.ts",
    "dev": "pnpm run content && vite",
    "build": "pnpm run content && vite build",
    "check": "pnpm run typecheck && pnpm run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.460.0",
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "gray-matter": "^4.0.3",
    "postcss": "^8.4.49",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.24.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unified": "^11.0.5",
    "vite": "^5.4.11"
  }
}
